{
  "preCommitTask": {
    "*.astro": "bunx astro check",
    "*.{ts,js,json,yml,yaml,astro}": "bunx eslint --fix"
  },
  "prePushTask": ["bunx vitest", "bunx playwright test"],
  "release": {
    "releaseToGithub": true
  },
  "changelog": {
    "changelogPath": "CHANGELOG.md",
    "generateChangelog": true
  },
  "packageManager": "bun"
}