---
import { buildUrl } from '../util/link';

export type SitemapProps = {
  readonly sitemapPath?: string;
  readonly showSitemap?: boolean;
};

type Props = SitemapProps;

const { showSitemap = true, sitemapPath = '/sitemap-index.xml' } = Astro.props;
const sitemapUrl = buildUrl(sitemapPath, Astro.site);
---
{showSitemap && <link rel='sitemap' href={sitemapUrl} />}