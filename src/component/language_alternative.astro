---
import { buildUrl, removeTrailingSlash } from '../util/link';

export type LanguageAlternativeProps = {
  languages?: string[];
  defaultLanguage?: string;
};

type Props = LanguageAlternativeProps;

const { languages, defaultLanguage } = Astro.props;
const canonicalURL = buildUrl(Astro.url.pathname, Astro.site);
---
{defaultLanguage && (
  <link
    rel='alternate'
    href={canonicalURL}
    hreflang='x-default'
  />
)}
{(languages && languages.length > 1) && languages.map((lang) => {
  const url = removeTrailingSlash(buildUrl(`/${lang}${Astro.url.pathname}`, Astro.site));

  return (
    <link
      href={url}
      rel='alternate'
      hreflang={lang}
    />
  );
})}