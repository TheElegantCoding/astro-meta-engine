---
import { removeTrailingSlash } from '../util/link';

export type LanguageAlternativeProps = {
  languages?: string[];
  defaultLanguage?: string;
};

type Props = LanguageAlternativeProps;

const { languages, defaultLanguage } = Astro.props;
const canonicalURL = Astro.site ? removeTrailingSlash(new URL(Astro.url.pathname, Astro.site)) : Astro.url;
---
{defaultLanguage && (
  <link
    rel='alternate'
    href={canonicalURL}
    hreflang='x-default'
  />
)}
{(languages && languages.length > 1) && languages.map((lang) => {
  const href = new URL(Astro.url.pathname, Astro.site);
  const url = removeTrailingSlash(new URL(`/${lang}${href.pathname}`, Astro.site));

  return (
    <link
      href={url}
      rel='alternate'
      hreflang={lang}
    />
  );
})}