---
import { buildUrl } from '../util/link';

export type FaviconProps = {
  readonly png?: string;
  readonly svg?: string;
  readonly ico?: string;
  readonly apple?: string;
  readonly manifest?: string;
};

type Props = FaviconProps;

const {
  png,
  svg,
  ico,
  apple,
  manifest
} = Astro.props;

const siteUrl = Astro.site;
const pngUrl = buildUrl(png ?? 'favicon.png', siteUrl);
const svgUrl = buildUrl(svg ?? 'favicon.svg', siteUrl);
const icoUrl = buildUrl(ico ?? 'favicon.ico', siteUrl);
const appleUrl = buildUrl(apple ?? 'apple-touch-icon.png', siteUrl);
const manifestUrl = buildUrl(manifest ?? 'site.webmanifest', siteUrl);
---
{png && (
  <link
    rel='icon'
    href={pngUrl}
    sizes='96x96'
    type='image/png'
  />
)}
{svg && (
  <link
    rel='icon'
    href={svgUrl}
    type='image/svg+xml'
  />
)}
{apple && (
  <link
    href={appleUrl}
    sizes='180x180'
    rel='apple-touch-icon'
  />
)}
{ico && (<link href={icoUrl} rel='shortcut icon' />)}
{manifest && <link rel='manifest' href={manifestUrl} />}